  create view "hostlens"."main_staging"."stg_hosts__dbt_tmp" as (
    -- stg_hosts.sql
-- Staging model: selects host-level attributes from the dim_hosts dimension
-- table. Normalises boolean flags and computes host tenure in days from
-- host_since date.
--
-- Source: DuckDB table 'dim_hosts' (created by src/pipeline.py)
-- Materialization: view



with source as (

    select
        host_id,
        host_name,

        -- Normalize superhost flag to boolean
        case
            when lower(cast(host_is_superhost as varchar)) in ('t', 'true', '1')
                then true
            else false
        end as is_superhost,

        -- Normalize identity verification flag
        case
            when lower(cast(host_identity_verified as varchar)) in ('t', 'true', '1')
                then true
            else false
        end as is_identity_verified,

        -- Host tenure in days (from host_since to today)
        cast(
            datediff(
                'day',
                try_cast(host_since as date),
                current_date
            ) as integer
        ) as host_tenure_days,

        calculated_host_listings_count  as total_listings,

        -- Host response metrics (may be null)
        host_response_rate,
        host_acceptance_rate,
        host_response_time

    from dim_hosts

    where host_id is not null

)

select * from source
  );

[0m21:21:14.611507 [debug] [Thread-2 (]: On model.hostlens.stg_listings: /* {"app": "dbt", "dbt_version": "1.11.12", "profile_name": "hostlens", "target_name": "dev", "node_id": "model.hostlens.stg_listings"} */

  
  create view "hostlens"."main_staging"."stg_listings__dbt_tmp" as (
    -- stg_listings.sql
-- Staging model: selects from the HostLens star schema fact_listings table,
-- applies light renaming and type casting for consistency across downstream
-- mart models.
--
-- Source: DuckDB table 'fact_listings' (created by src/pipeline.py)
-- Materialization: view (refreshed on every dbt run)



with source as (

    select
        id                              as listing_id,
        name                            as listing_name,
        host_id,
        neighbourhood_group_cleansed    as borough,
        neighbourhood_cleansed          as neighbourhood,
        cast(latitude as double)        as latitude,
        cast(longitude as double)       as longitude,
        room_type,
        cast(price as double)           as price_usd,
        cast(minimum_nights as integer) as minimum_nights,
        cast(number_of_reviews as integer) as review_count,

        -- Nullable enriched columns (may be null if pipeline hasn't run ML)
        cast(occupancy_rate as double)          as occupancy_rate,
        cast(estimated_annual_revenue as double) as estimated_annual_revenue_usd,

        -- Host profile flags
        host_is_superhost,
        calculated_host_listings_count  as host_listing_count,

        -- Review scores
        review_scores_rating,
        review_scores_cleanliness,
        review_scores_location,
        review_scores_communication,

        -- Availability
        availability_365

    from fact_listings

    where
        price_usd > 0
        and price_usd <= 10000  -- exclude extreme outliers
        and listing_id is not null

)

select * from source
  );

