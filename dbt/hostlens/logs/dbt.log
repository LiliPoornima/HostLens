  create view "hostlens"."main_staging"."stg_reviews__dbt_tmp" as (
    -- stg_reviews.sql
-- Staging model: selects review-level data from the dim_reviews dimension
-- table. Parses review dates and cleans comment text length.
--
-- Source: DuckDB table 'dim_reviews' (created by src/pipeline.py)
-- Materialization: view



with source as (

    select
        id                              as review_id,
        listing_id,
        reviewer_id,

        -- Parse review date
        try_cast(date as date)          as review_date,

        -- Comment length for text analytics
        len(coalesce(comments, ''))     as comment_length_chars,

        -- Truncated preview (first 200 chars) for display
        substr(coalesce(comments, ''), 1, 200) as comment_preview

    from dim_reviews

    where
        id is not null
        and listing_id is not null

)

select * from source
  );

